# Securities-recommendation API target
# Local: http://localhost:8089
# Deployed dev: https://api.askmyfi.dev
# Deployed prod: https://api.askmyfi.com
API_BASE_URL=http://localhost:8089

# Optional local direct-service routing. Use these when running multiple
# securities-recommendation services on separate ports with LOCAL_MODE=true.
LOCAL_MODE=false
# FIN_ENGINE_BASE_URL=http://localhost:8080
# MODEL_PORTFOLIO_BASE_URL=http://localhost:8081

# ── Tool-calling LLM Provider (pick one) ─────────────────────────────
# The agent needs an OpenAI-compatible LLM with native function calling for
# tool planning only. Final answer generation is handled by the Glass-Box
# Reasoner + Answerer configured through Reasoning_LLM_TiFin env vars.

# Option 1: Self-hosted GPU (recommended; company VPN/GCP only)
LLM_BASE_URL=http://103.42.51.88:2205/
LLM_API_KEY=anything works
LLM_MODEL=orchestrator

# Option 2: Groq or another OpenAI-compatible provider
# Not currently validated for the full Glass-Box integration path.
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your-groq-key
# LLM_MODEL=llama-3.3-70b-versatile

# ── LLM Parameters ───────────────────────────────────────────────────
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=16384

# ── Auth ──────────────────────────────────────────────────────────────
# false for local development, true for deployed services
ENABLE_AUTH=false

# ── Reasoning architecture (Glass-Box) ───────────────────────────────
# two_layer:   Reasoner + Answerer (default — lower latency)
# three_layer: Reasoner + Answerer + Verifier with up to 2 retries
#              (stricter grounding, higher latency)
REASONING_ARCHITECTURE=two_layer

# ── GCP Credentials (for running backend services locally) ───────────
# Backend services need GCP S2S auth to call external APIs.
# Set this in your shell, not in .env:
#   export GOOGLE_APPLICATION_CREDENTIALS='/path/to/gcp-key-dev.json'
