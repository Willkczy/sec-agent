# Securities-recommendation API target
# Local: http://localhost:8089
# Deployed dev: https://api.askmyfi.dev
# Deployed prod: https://api.askmyfi.com
API_BASE_URL=http://localhost:8089

# ── LLM Provider (pick one) ──────────────────────────────────────────
# The agent needs an OpenAI-compatible LLM for planning and rendering.

# Option 1: Groq (recommended for local dev — fast, free tier available)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_your-groq-key
LLM_MODEL=llama-3.3-70b-versatile

# Option 2: Self-hosted GPU (company VPN/GCP only)
# LLM_BASE_URL=http://103.42.51.88:2205/
# LLM_API_KEY=123-123-123
# LLM_MODEL=orchestrator

# ── LLM Parameters ───────────────────────────────────────────────────
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=8192

# ── Auth ──────────────────────────────────────────────────────────────
# false for local development, true for deployed services
ENABLE_AUTH=false

# ── GCP Credentials (for running backend services locally) ───────────
# Backend services need GCP S2S auth to call external APIs.
# Set this in your shell, not in .env:
#   export GOOGLE_APPLICATION_CREDENTIALS='/path/to/gcp-key-dev.json'
